From 0000000000000000000000000000000000000001 Mon Sep 17 00:00:00 2001
From: Boot Debug <noreply@qti.qualcomm.com>
Date: Mon, 30 Jun 2026 00:00:00 +0000
Subject: [DEBUG] initramfs-framework: /dev/kmsg timing markers for udev and
 rootfs modules

Instrumentation only. Emits BOOTDBG markers to /dev/kmsg (visible in dmesg)
around the expensive steps in the initramfs userspace path:
  - udev module: udevadm trigger + udevadm settle
  - rootfs module: rootfs_run entry, each sleep-retry, and mount completion

Lets us attribute the silent init->EXT4-mount gap to udev settle, the
rootfs sleep-retry loop, or (separately) ostree-prepare-root. No
behavioural change. Revert after measurement.

Upstream-Status: Inappropriate [debug instrumentation]
---
diff --git a/meta/recipes-core/initrdscripts/initramfs-framework/rootfs b/meta/recipes-core/initrdscripts/initramfs-framework/rootfs
index df0cbfb091..7146b06cf1 100644
--- a/meta/recipes-core/initrdscripts/initramfs-framework/rootfs
+++ b/meta/recipes-core/initrdscripts/initramfs-framework/rootfs
@@ -7,6 +7,7 @@ rootfs_enabled() {
 }
 
 rootfs_run() {
+        echo "BOOTDBG rootfs_run start $(cat /proc/uptime)" > /dev/kmsg 2>/dev/null
         if [ -z "$ROOTFS_DIR" ]; then
 		return
         fi
@@ -63,7 +64,10 @@ rootfs_run() {
 			fi
 		fi
 		debug "Sleeping for $delay second(s) to wait for root to settle..."
+		echo "BOOTDBG rootfs_run sleeping (root not ready) C=$C delay=$delay $(cat /proc/uptime)" > /dev/kmsg 2>/dev/null
 		sleep $delay
 		C=$(( $C + 1 ))
 	done
+
+	echo "BOOTDBG rootfs_run done (mounted) $(cat /proc/uptime)" > /dev/kmsg 2>/dev/null
 }
diff --git a/meta/recipes-core/initrdscripts/initramfs-framework/udev b/meta/recipes-core/initrdscripts/initramfs-framework/udev
index 4898b89246..f04ae36ca4 100644
--- a/meta/recipes-core/initrdscripts/initramfs-framework/udev
+++ b/meta/recipes-core/initrdscripts/initramfs-framework/udev
@@ -45,6 +45,9 @@ udev_run() {
 	sh -c "exec 4< /dev/console" || { exec 0> /dev/null; exec 1> /dev/null; exec 2> /dev/null; }
 
 	$_UDEV_DAEMON --daemon
+	echo "BOOTDBG udev trigger start $(cat /proc/uptime)" > /dev/kmsg 2>/dev/null
 	udevadm trigger --action=add
+	echo "BOOTDBG udev settle start $(cat /proc/uptime)" > /dev/kmsg 2>/dev/null
 	udevadm settle
+	echo "BOOTDBG udev settle done $(cat /proc/uptime)" > /dev/kmsg 2>/dev/null
 }
