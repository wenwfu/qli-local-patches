++/* SPDX-License-Identifier: LGPL-2.1-or-later */
++/* BOOTPROF: ftrace trace_marker instrumentation for the systemd startup main
++ * path and udev event processing. Instrumentation only -- drop the
++ * local-patches entry to remove.
++ *
++ * Writes Perfetto-compatible markers to the top-level trace_marker:
++ *   B|<pid>|<name>   begin a slice
++ *   E|<pid>          end the innermost slice
++ *   I|<pid>|<name>   instant event
++ * These render as nested slices in the Perfetto UI, on the writing pid's
++ * track, aligned with sched/block/power events on the same timeline.
++ *
++ * Writing tracefs from systemd (init_t) / udevd (udev_t) requires an SELinux
++ * allow rule (see the qcom_bootprof refpolicy module in local-patches); with
++ * SELinux enforcing and no such rule, the writes are denied and silently
++ * dropped.
++ *
++ * All operations are best-effort: the fd is opened lazily and, on failure, is
++ * retried on the next marker (failure is never latched), so an early-boot
++ * open failure does not disable markers for the rest of the process lifetime.
++ * If tracefs is unavailable the writes are silently skipped and boot is
++ * unaffected. */
++
++#include <errno.h>
++#include <fcntl.h>
++#include <unistd.h>
++
++#include "bootprof.h"
++#include "fd-util.h"
++#include "fileio.h"
