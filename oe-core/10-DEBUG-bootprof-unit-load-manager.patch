++/* tracefs (preferred) and debugfs fallback trace_marker paths. */
++#define BOOTPROF_MARKER_TRACEFS "/sys/kernel/tracing/trace_marker"
++#define BOOTPROF_MARKER_DEBUGFS "/sys/kernel/debug/tracing/trace_marker"
++
++static int bootprof_marker_fd = -EBADF;
++
++static int bootprof_fd(void) {
++        /* Retry until we succeed: do NOT latch failure. In early boot the first
++         * open can fail (tracefs timing), and a one-shot latch would then
++         * disable markers for this process' entire lifetime -- exactly the
++         * first-boot pid 1 window we care about. So we cache only a SUCCESSFUL
++         * fd; on failure we fall through and try again on the next marker. */
++        if (bootprof_marker_fd >= 0)
++                return bootprof_marker_fd;
++
++        /* Prefer the tracefs mount, fall back to the debugfs path. O_CLOEXEC so
++         * the fd is not leaked into forked children. */
++        bootprof_marker_fd = open(BOOTPROF_MARKER_TRACEFS, O_WRONLY|O_CLOEXEC|O_NOCTTY);
++        if (bootprof_marker_fd < 0)
++                bootprof_marker_fd = open(BOOTPROF_MARKER_DEBUGFS, O_WRONLY|O_CLOEXEC|O_NOCTTY);
++
++        /* BOOTPROF: surface why markers are missing. Logged on EVERY failure
++         * (log_warning_errno, not log_once) so each failed attempt is visible;
++         * note this can be very verbose on the boot hot path when writes are
++         * persistently denied. errno tells the story: EACCES = SELinux denial
++         * (need the qcom_bootprof allow rule), ENOENT = tracefs not mounted. */
++        if (bootprof_marker_fd < 0)
++                log_warning_errno(errno,
++                                  "BOOTPROF: failed to open trace_marker (%s / %s): %m",
++                                  BOOTPROF_MARKER_TRACEFS, BOOTPROF_MARKER_DEBUGFS);
++
++        return bootprof_marker_fd;
++}
++
++static void bootprof_write(const char *s) {
++        int fd;
++
++        fd = bootprof_fd();
++        if (fd < 0)
++                return;
++
++        /* Report every write error (verbose by design). A denied write here
++         * (EACCES) means the fd opened but SELinux blocks writes -- again the
++         * qcom_bootprof allow rule. */
++        if (write(fd, s, strlen(s)) < 0)
++                log_warning_errno(errno,
++                                  "BOOTPROF: failed to write trace_marker: %m");
++}
++
++void bootprof_begin(const char *name) {
++        char buf[320];
++
++        assert(name);
++        /* snprintf (truncating), NOT xsprintf: name may be up to caller's buffer
++         * size (e.g. 256); with the "B|<pid>|" prefix it could exceed the buffer,
++         * and xsprintf would assert and abort the process. Truncation is fine for
++         * a diagnostic marker; aborting a udev worker here would break boot. */
++        (void) snprintf(buf, sizeof(buf), "B|" PID_FMT "|%s", getpid_cached(), name);
++        bootprof_write(buf);
++}
++
++void bootprof_end(void) {
++        char buf[64];
++
++        (void) snprintf(buf, sizeof(buf), "E|" PID_FMT, getpid_cached());
++        bootprof_write(buf);
++}
++
++void bootprof_instant(const char *name) {
++        char buf[320];
++
++        assert(name);
++        (void) snprintf(buf, sizeof(buf), "I|" PID_FMT "|%s", getpid_cached(), name);
++        bootprof_write(buf);
++}
