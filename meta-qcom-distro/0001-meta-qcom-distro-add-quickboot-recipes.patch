From 0000000000000000000000000000000000000010 Mon Sep 17 00:00:00 2001
From: wenwfu <wenwfu@qti.qualcomm.com>
Date: Mon, 13 Jul 2026 14:00:00 +0530
Subject: [PATCH] meta-qcom-distro: add quickboot recipes (git SRC_URI) and
 wire into multimedia image

Add quickboot-audio/camera/display recipes under recipes-support/quickboot/,
fetching sources from github.com/wenwfu/quickboot (branch multi-target, pinned
SRCREV). Install per-machine files from the git checkout for iq-9075-evk and
rb3gen2-core-kit. Wire the three packages into qcom-multimedia-image per
machine so the image still builds for unsupported MACHINEs.

Signed-off-by: wenwfu <wenwfu@qti.qualcomm.com>
---
diff --git a/recipes-products/images/qcom-multimedia-image.bb b/recipes-products/images/qcom-multimedia-image.bb
index e4f01fa..fe107b6 100644
--- a/recipes-products/images/qcom-multimedia-image.bb
+++ b/recipes-products/images/qcom-multimedia-image.bb
@@ -43,5 +43,12 @@ CORE_IMAGE_BASE_INSTALL += " \
 # IMSDK currently only used and tested on ARMv8 (aarch64) machines.
 CORE_IMAGE_BASE_INSTALL:append:aarch64 = " gst-plugins-imsdk-oss"
 
+# QuickBoot early-boot optimizations (audio/camera/display). The recipes' own
+# COMPATIBLE_MACHINE limits each to its supported targets, so these are only
+# added for machines that ship the corresponding files.
+QUICKBOOT_INSTALL = "quickboot-audio quickboot-camera quickboot-display"
+CORE_IMAGE_BASE_INSTALL:append:iq-9075-evk = " ${QUICKBOOT_INSTALL}"
+CORE_IMAGE_BASE_INSTALL:append:rb3gen2-core-kit = " ${QUICKBOOT_INSTALL}"
+
 # let's make sure we have a good image.
 REQUIRED_DISTRO_FEATURES += "wayland"
diff --git a/recipes-support/quickboot/quickboot-audio_1.0.bb b/recipes-support/quickboot/quickboot-audio_1.0.bb
new file mode 100644
index 0000000..6747543
--- /dev/null
+++ b/recipes-support/quickboot/quickboot-audio_1.0.bb
@@ -0,0 +1,75 @@
+SUMMARY = "Early Audio Boot Optimizations"
+LICENSE = "CLOSED"
+inherit systemd
+
+SRC_URI = "git://github.com/wenwfu/quickboot.git;protocol=https;branch=multi-target"
+SRCREV = "03ca6708d61138f3db33f8fea35bcca48b391f92"
+
+# Per-machine files live under quickboot-audio/files/<MACHINE>/ in the repo.
+QB_FILES = "${S}/quickboot-audio/files/${MACHINE}"
+
+RDEPENDS:${PN} += "bash"
+
+COMPATIBLE_MACHINE = "(iq-9075-evk|rb3gen2-core-kit)"
+
+SYSTEMD_AUTO_ENABLE = "enable"
+
+# IQ-9075 EVK (SA8775P / lemans)
+SYSTEMD_SERVICE:${PN}:iq-9075-evk = "early_audio_play_app.service"
+
+do_install:iq-9075-evk() {
+    install -d ${D}${sysconfdir}/modules-load.d/
+    install -m 0644 ${QB_FILES}/audio-modules.conf ${D}${sysconfdir}/modules-load.d/
+
+    install -d ${D}${sysconfdir}/udev/rules.d/
+    install -m 0644 ${QB_FILES}/01-pipewire-audio.rules ${D}${sysconfdir}/udev/rules.d/
+
+    install -d ${D}${sysconfdir}/systemd/system/
+    install -m 0644 ${QB_FILES}/pipewire.service ${D}${sysconfdir}/systemd/system/
+    install -d ${D}${sysconfdir}/systemd/system/pipewire.socket.d/
+    install -m 0644 ${QB_FILES}/pipewire.socket.conf \
+        ${D}${sysconfdir}/systemd/system/pipewire.socket.d/zz-quickboot.conf
+    install -d ${D}${sysconfdir}/systemd/system/pipewire-manager.socket.d/
+    install -m 0644 ${QB_FILES}/pipewire-manager.socket.conf \
+        ${D}${sysconfdir}/systemd/system/pipewire-manager.socket.d/zz-quickboot.conf
+    install -m 0644 ${QB_FILES}/early_audio_play_app.service ${D}${sysconfdir}/systemd/system/
+
+    install -d ${D}${bindir}/
+    install -m 0755 ${QB_FILES}/audio_play_app.sh ${D}${bindir}/
+
+    install -d ${D}/usr/share/sounds/
+    install -m 0644 ${QB_FILES}/sample-3s.wav ${D}/usr/share/sounds/
+}
+
+FILES:${PN} += "${sysconfdir}/modules-load.d/* ${sysconfdir}/udev/rules.d/* ${sysconfdir}/systemd/system/* ${bindir}/* /usr/share/sounds/*"
+FILES:${PN}:iq-9075-evk += "${sysconfdir}/systemd/system/*.socket.d/*"
+
+# Kodiak (sc7280 / qcm6490)
+SYSTEMD_SERVICE:${PN}:rb3gen2-core-kit = "early_audio_play_app.service"
+
+do_install:rb3gen2-core-kit() {
+    install -d ${D}${sysconfdir}/modules-load.d/
+    install -m 0644 ${QB_FILES}/audio-modules.conf ${D}${sysconfdir}/modules-load.d/10-audio-modules.conf
+
+    install -d ${D}${sysconfdir}/udev/rules.d/
+    install -m 0644 ${QB_FILES}/01-pipewire-audio.rules ${D}${sysconfdir}/udev/rules.d/
+
+    # pipewire is installed as a full unit; the sockets as drop-ins.
+    install -d ${D}${sysconfdir}/systemd/system/
+    install -m 0644 ${QB_FILES}/pipewire.service ${D}${sysconfdir}/systemd/system/
+    install -d ${D}${sysconfdir}/systemd/system/pipewire.socket.d/
+    install -m 0644 ${QB_FILES}/pipewire.socket.conf \
+        ${D}${sysconfdir}/systemd/system/pipewire.socket.d/zz-quickboot.conf
+    install -d ${D}${sysconfdir}/systemd/system/pipewire-manager.socket.d/
+    install -m 0644 ${QB_FILES}/pipewire-manager.socket.conf \
+        ${D}${sysconfdir}/systemd/system/pipewire-manager.socket.d/zz-quickboot.conf
+    install -m 0644 ${QB_FILES}/early_audio_play_app.service ${D}${sysconfdir}/systemd/system/
+
+    install -d ${D}${bindir}/
+    install -m 0755 ${QB_FILES}/audio_play_app.sh ${D}${bindir}/
+
+    install -d ${D}/data/
+    install -m 0644 ${QB_FILES}/sample-3s.wav ${D}/data/
+}
+
+FILES:${PN}:rb3gen2-core-kit += "${sysconfdir}/modules-load.d/* ${sysconfdir}/udev/rules.d/* ${sysconfdir}/systemd/system/* ${bindir}/* ${sysconfdir}/systemd/system/*.socket.d/* /data/*"
diff --git a/recipes-support/quickboot/quickboot-camera_1.0.bb b/recipes-support/quickboot/quickboot-camera_1.0.bb
new file mode 100644
index 0000000..d229aed
--- /dev/null
+++ b/recipes-support/quickboot/quickboot-camera_1.0.bb
@@ -0,0 +1,59 @@
+SUMMARY = "Early Camera Boot Optimizations"
+LICENSE = "CLOSED"
+inherit systemd
+
+SRC_URI = "git://github.com/wenwfu/quickboot.git;protocol=https;branch=multi-target"
+SRCREV = "03ca6708d61138f3db33f8fea35bcca48b391f92"
+
+# Per-machine files live under quickboot-camera/files/<MACHINE>/ in the repo.
+QB_FILES = "${S}/quickboot-camera/files/${MACHINE}"
+
+RDEPENDS:${PN} += "bash"
+
+COMPATIBLE_MACHINE = "(iq-9075-evk|rb3gen2-core-kit)"
+
+SYSTEMD_AUTO_ENABLE = "enable"
+
+# IQ-9075 EVK (SA8775P / lemans)
+SYSTEMD_SERVICE:${PN}:iq-9075-evk = "early_cam_preview_app.service"
+
+do_install:iq-9075-evk() {
+    install -d ${D}${sysconfdir}/modules-load.d/
+    install -m 0644 ${QB_FILES}/camera-modules.conf ${D}${sysconfdir}/modules-load.d/
+
+    install -d ${D}${sysconfdir}/udev/rules.d/
+    install -m 0644 ${QB_FILES}/02-cam-server.rules ${D}${sysconfdir}/udev/rules.d/
+
+    install -d ${D}${sysconfdir}/systemd/system/
+    install -m 0644 ${QB_FILES}/cam-server.service ${D}${sysconfdir}/systemd/system/
+    install -m 0644 ${QB_FILES}/early_cam_preview_app.service ${D}${sysconfdir}/systemd/system/
+
+    install -d ${D}${bindir}/
+    install -m 0755 ${QB_FILES}/cam_preview_app.sh ${D}${bindir}/
+    install -m 0755 ${QB_FILES}/iq9075-first-boot-cam-setup.sh ${D}${bindir}/
+}
+
+# Kodiak (sc7280 / qcm6490)
+# cam-server is device-triggered by 02-cam-server.rules, so it is not enabled
+# into multi-user.target.
+SYSTEMD_SERVICE:${PN}:rb3gen2-core-kit = ""
+
+do_install:rb3gen2-core-kit() {
+    install -d ${D}${sysconfdir}/modules-load.d/
+    install -m 0644 ${QB_FILES}/camera-modules.conf ${D}${sysconfdir}/modules-load.d/20-camera-modules.conf
+
+    install -d ${D}${sysconfdir}/udev/rules.d/
+    install -m 0644 ${QB_FILES}/02-cam-server.rules ${D}${sysconfdir}/udev/rules.d/
+
+    install -d ${D}${sysconfdir}/systemd/system/
+    install -m 0644 ${QB_FILES}/cam-server.service ${D}${sysconfdir}/systemd/system/
+    install -m 0644 ${QB_FILES}/early_cam_preview_app.service ${D}${sysconfdir}/systemd/system/
+
+    install -m 0644 ${QB_FILES}/camxoverridesettings.txt ${D}/camxoverridesettings.txt
+
+    install -d ${D}${bindir}/
+    install -m 0755 ${QB_FILES}/cam_preview_app.sh ${D}${bindir}/
+}
+
+FILES:${PN} += "${sysconfdir}/modules-load.d/* ${sysconfdir}/udev/rules.d/* ${sysconfdir}/systemd/system/* ${bindir}/*"
+FILES:${PN}:append:rb3gen2-core-kit = " /camxoverridesettings.txt"
diff --git a/recipes-support/quickboot/quickboot-display_1.0.bb b/recipes-support/quickboot/quickboot-display_1.0.bb
new file mode 100644
index 0000000..8bcc928
--- /dev/null
+++ b/recipes-support/quickboot/quickboot-display_1.0.bb
@@ -0,0 +1,51 @@
+SUMMARY = "Early Display Boot Optimizations"
+LICENSE = "CLOSED"
+inherit systemd
+
+SRC_URI = "git://github.com/wenwfu/quickboot.git;protocol=https;branch=multi-target"
+SRCREV = "03ca6708d61138f3db33f8fea35bcca48b391f92"
+
+# Per-machine files live under quickboot-display/files/<MACHINE>/ in the repo.
+QB_FILES = "${S}/quickboot-display/files/${MACHINE}"
+
+RDEPENDS:${PN} += "bash"
+
+COMPATIBLE_MACHINE = "(iq-9075-evk|rb3gen2-core-kit)"
+
+# IQ-9075 EVK (SA8775P / lemans)
+do_install:iq-9075-evk() {
+    install -d ${D}${sysconfdir}/modules-load.d/
+    install -m 0644 ${QB_FILES}/display-modules.conf ${D}${sysconfdir}/modules-load.d/
+
+    install -d ${D}${sysconfdir}/modprobe.d/
+    install -m 0644 ${QB_FILES}/drm-modprobe.conf ${D}${sysconfdir}/modprobe.d/
+
+    install -d ${D}${sysconfdir}/udev/rules.d/
+    install -m 0644 ${QB_FILES}/03-drm.rules ${D}${sysconfdir}/udev/rules.d/
+
+    install -d ${D}${sysconfdir}/systemd/system/
+    install -m 0644 ${QB_FILES}/weston.service ${D}${sysconfdir}/systemd/system/
+    install -m 0644 ${QB_FILES}/weston.socket ${D}${sysconfdir}/systemd/system/
+}
+
+# Kodiak (sc7280 / qcm6490)
+do_install:rb3gen2-core-kit() {
+    install -d ${D}${sysconfdir}/modules-load.d/
+    install -m 0644 ${QB_FILES}/display-modules.conf ${D}${sysconfdir}/modules-load.d/00-display-modules.conf
+
+    install -d ${D}${sysconfdir}/modprobe.d/
+    install -m 0644 ${QB_FILES}/00-msm-softdep.conf ${D}${sysconfdir}/modprobe.d/
+    install -m 0644 ${QB_FILES}/blacklist-bootspeed.conf ${D}${sysconfdir}/modprobe.d/
+
+    install -d ${D}${sysconfdir}/udev/rules.d/
+    install -m 0644 ${QB_FILES}/03-drm.rules ${D}${sysconfdir}/udev/rules.d/
+
+    # weston is installed as a full unit; the socket as a drop-in.
+    install -d ${D}${sysconfdir}/systemd/system/
+    install -m 0644 ${QB_FILES}/weston.service ${D}${sysconfdir}/systemd/system/
+    install -d ${D}${sysconfdir}/systemd/system/weston.socket.d/
+    install -m 0644 ${QB_FILES}/weston.socket.conf \
+        ${D}${sysconfdir}/systemd/system/weston.socket.d/zz-quickboot.conf
+}
+
+FILES:${PN} += "${sysconfdir}/modules-load.d/* ${sysconfdir}/modprobe.d/* ${sysconfdir}/udev/rules.d/* ${sysconfdir}/systemd/system/* ${sysconfdir}/systemd/system/*.socket.d/*"
