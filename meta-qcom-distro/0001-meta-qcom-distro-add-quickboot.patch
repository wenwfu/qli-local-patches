From eba79588af7bcf981fcf2bba3233214cad30ab8e Mon Sep 17 00:00:00 2001
From: Wenwen Fu <wenwfu@qti.qualcomm.com>
Date: Thu, 23 Jul 2026 14:09:06 +0800
Subject: [PATCH] meta-qcom-distro: add quickboot recipes, wire into image,
 enable by default

Add the QuickBoot recipes under recipes-quickboot/: subsystem/ holds
quickboot-{camera,audio,display,udev} and core/ holds quickboot-core (the
shared runtime that detects the board's SoC family, watches
/etc/quickboot/request, and applies/reverts each subsystem's manifest). All
fetch sources from github.com/wenwfu/quickboot (branch
quickboot-runtime-manager, pinned SRCREV) via the shared quickboot-git.inc.
Each recipe stages files/common + files/<SOC_FAMILY> into the flat profile
library; the customer-reference apps under examples/ and the dev-only push.bat
helpers under test/ are not installed by any recipe.

camxoverridesettings.txt and the camera-sensor-prune.sh setup script are not
installed unconditionally; they stage into the profile payload and are linked
into /etc/camera/ only when camera=on, via the camera manifests.

Wire the packages into qcom-multimedia-image via PACKAGE_INSTALL_ATTEMPTONLY
(a weak RRECOMMENDS), gated on the "quickboot" DISTRO_FEATURE. Attempt-only
means each recipe's COMPATIBLE_MACHINE decides inclusion -- packages are
silently skipped on unsupported SoC families -- so the image stays
SoC-agnostic with no per-family keying. Each recipe also inherits
features_check with REQUIRED_DISTRO_FEATURES = "quickboot".

Enable the "quickboot" DISTRO_FEATURE by default (add it to qcom-base.inc's
DISTRO_FEATURES) so the packages are built and pulled in out of the box.

Signed-off-by: Wenwen Fu <wenwfu@qti.qualcomm.com>
---
 conf/distro/include/qcom-base.inc             |  1 +
 .../images/qcom-multimedia-image.bb           | 10 +++
 recipes-quickboot/core/quickboot-core_1.0.bb  | 63 +++++++++++++++++++
 recipes-quickboot/quickboot-git.inc           | 23 +++++++
 .../subsystem/quickboot-audio_1.0.bb          | 45 +++++++++++++
 .../subsystem/quickboot-camera_1.0.bb         | 53 ++++++++++++++++
 .../subsystem/quickboot-display_1.0.bb        | 45 +++++++++++++
 .../subsystem/quickboot-udev_1.0.bb           | 32 ++++++++++
 8 files changed, 272 insertions(+)
 create mode 100644 recipes-quickboot/core/quickboot-core_1.0.bb
 create mode 100644 recipes-quickboot/quickboot-git.inc
 create mode 100644 recipes-quickboot/subsystem/quickboot-audio_1.0.bb
 create mode 100644 recipes-quickboot/subsystem/quickboot-camera_1.0.bb
 create mode 100644 recipes-quickboot/subsystem/quickboot-display_1.0.bb
 create mode 100644 recipes-quickboot/subsystem/quickboot-udev_1.0.bb

diff --git a/conf/distro/include/qcom-base.inc b/conf/distro/include/qcom-base.inc
index fbdffb2..a3a66d8 100644
--- a/conf/distro/include/qcom-base.inc
+++ b/conf/distro/include/qcom-base.inc
@@ -22,6 +22,7 @@ DISTRO_FEATURES:append = " \
     pam \
     pni-names \
     polkit \
+    quickboot \
     security \
     tpm2 \
     virtualization \
diff --git a/recipes-products/images/qcom-multimedia-image.bb b/recipes-products/images/qcom-multimedia-image.bb
index e4f01fa..c99e05d 100644
--- a/recipes-products/images/qcom-multimedia-image.bb
+++ b/recipes-products/images/qcom-multimedia-image.bb
@@ -43,5 +43,15 @@ CORE_IMAGE_BASE_INSTALL += " \
 # IMSDK currently only used and tested on ARMv8 (aarch64) machines.
 CORE_IMAGE_BASE_INSTALL:append:aarch64 = " gst-plugins-imsdk-oss"

+# QuickBoot early-boot optimizations, gated on the "quickboot" DISTRO_FEATURE.
+# Installed attempt-only (a weak RRECOMMENDS): each quickboot recipe's
+# COMPATIBLE_MACHINE limits it to its SoC family, and an attempt-only install
+# silently skips a package on families where it is not compatible -- so the
+# image needs no per-SoC-family keying and stays SoC-agnostic. On an
+# unsupported family the packages are simply not pulled in; where the feature
+# is off the list is empty.
+PACKAGE_INSTALL_ATTEMPTONLY:append = " ${@bb.utils.contains('DISTRO_FEATURES', 'quickboot', \
+    'quickboot-core quickboot-audio quickboot-camera quickboot-display quickboot-udev', '', d)}"
+
 # let's make sure we have a good image.
 REQUIRED_DISTRO_FEATURES += "wayland"
diff --git a/recipes-quickboot/core/quickboot-core_1.0.bb b/recipes-quickboot/core/quickboot-core_1.0.bb
new file mode 100644
index 0000000..0664e78
--- /dev/null
+++ b/recipes-quickboot/core/quickboot-core_1.0.bb
@@ -0,0 +1,63 @@
+SUMMARY = "QuickBoot runtime optimization core"
+DESCRIPTION = "Detects the running board's SoC family, watches \
+/etc/quickboot/request, and activates or reverts per-subsystem \
+(camera/audio/display/udev) boot optimizations at runtime by symlinking payload \
+from /usr/share/quickboot/profiles/<soc-family>/<subsystem>/ into the live /etc \
+tree."
+
+require ../quickboot-git.inc
+
+# Gated on the "quickboot" DISTRO_FEATURE: skipped entirely unless the distro
+# enables it.
+inherit systemd features_check
+REQUIRED_DISTRO_FEATURES = "quickboot"
+
+RDEPENDS:${PN} += "bash"
+
+COMPATIBLE_MACHINE = "(qcm6490|qcs9100)"
+
+# Records the build-time SOC_FAMILY into the rootfs, so this package's content
+# is machine-specific.
+PACKAGE_ARCH = "${MACHINE_ARCH}"
+
+QB_SRC = "${S}/core/files"
+
+# The .path watcher is what we enable at boot; it starts the oneshot .service
+# on request-node changes.
+SYSTEMD_SERVICE:${PN} = "quickboot-core.path"
+SYSTEMD_AUTO_ENABLE = "enable"
+
+python () {
+    if not d.getVar("SOC_FAMILY"):
+        bb.fatal("SOC_FAMILY is not set for MACHINE '%s'; quickboot profiles are "
+                 "keyed by SoC family. Ensure the machine includes a "
+                 "conf/machine/include/qcom-*.inc that sets SOC_FAMILY." % d.getVar("MACHINE"))
+}
+
+do_install() {
+    install -d ${D}${bindir}/
+    install -m 0755 ${QB_SRC}/quickboot-apply ${D}${bindir}/
+
+    install -d ${D}${systemd_system_unitdir}/
+    install -m 0644 ${QB_SRC}/quickboot-core.path ${D}${systemd_system_unitdir}/
+    install -m 0644 ${QB_SRC}/quickboot-core.service ${D}${systemd_system_unitdir}/
+
+    # Control node + state dir live under /etc (writable on ostree). The SoC
+    # family is fixed at build time from ${SOC_FAMILY}; quickboot-apply reads it
+    # from /etc/quickboot/soc-family at runtime to pick the profile directory.
+    install -d ${D}${sysconfdir}/quickboot/active/
+    echo "${SOC_FAMILY}" > ${D}${sysconfdir}/quickboot/soc-family
+
+    # Pre-seed the control node with every subsystem off. Users flip values to
+    # "on" to enable. It is a conffile so package upgrades keep local edits.
+    install -m 0644 ${QB_SRC}/request ${D}${sysconfdir}/quickboot/request
+}
+
+# Preserve the user's edited request across upgrades.
+CONFFILES:${PN} = "${sysconfdir}/quickboot/request"
+
+FILES:${PN} += " \
+    ${bindir}/* \
+    ${systemd_system_unitdir}/* \
+    ${sysconfdir}/quickboot \
+"
diff --git a/recipes-quickboot/quickboot-git.inc b/recipes-quickboot/quickboot-git.inc
new file mode 100644
index 0000000..3dcd1c2
--- /dev/null
+++ b/recipes-quickboot/quickboot-git.inc
@@ -0,0 +1,23 @@
+# Common git source definition for the QuickBoot recipes.
+#
+# The QuickBoot sources live in one GitHub repo; each recipe fetches the whole
+# tree at a pinned SRCREV and installs its own slice from ${S}. To bump the
+# version, update SRCREV (and PV) here in one place.
+#
+# NOTE: this deploys recipes into meta-qcom-distro (an upstream Qualcomm layer);
+# these files are a local addition and are not tracked by that layer's upstream.
+
+HOMEPAGE = "https://github.com/wenwfu/quickboot"
+LICENSE = "BSD-3-Clause"
+LIC_FILES_CHKSUM = "file://LICENSE.txt;md5=223037c4be0bfc6cf757035432adf983"
+
+# Pinned revision on branch quickboot-runtime-manager. Bump to move forward.
+SRC_URI = "git://github.com/wenwfu/quickboot.git;protocol=https;branch=quickboot-runtime-manager"
+SRCREV = "a589e7a433ec3dadfba292f0e28b667f5191aa67"
+
+PV = "1.0+git${SRCPV}"
+
+# S is left at its bitbake.conf default (${UNPACKDIR}/${BP}). This OE release
+# sets BB_GIT_DEFAULT_DESTSUFFIX = "${BP}", so the git checkout unpacks straight
+# to ${S}; recipes reach ${S}/subsystems/<subsys>/files/... and ${S}/core/
+# files/... . Do NOT set S = "${UNPACKDIR}/git" -- do_qa_unpack fatals on it.
diff --git a/recipes-quickboot/subsystem/quickboot-audio_1.0.bb b/recipes-quickboot/subsystem/quickboot-audio_1.0.bb
new file mode 100644
index 0000000..851dfc4
--- /dev/null
+++ b/recipes-quickboot/subsystem/quickboot-audio_1.0.bb
@@ -0,0 +1,45 @@
+SUMMARY = "Early Audio Boot Optimizations"
+
+require ../quickboot-git.inc
+
+# Gated on the "quickboot" DISTRO_FEATURE: skipped entirely unless the distro
+# enables it.
+inherit features_check
+REQUIRED_DISTRO_FEATURES = "quickboot"
+
+RDEPENDS:${PN} += "bash quickboot-core"
+
+COMPATIBLE_MACHINE = "(qcm6490|qcs9100)"
+
+# Source slices in the fetched git tree: common (shared) and family payload.
+# examples/audio/ (demo apps) is customer reference only and is NOT installed.
+QB_COMMON = "${S}/subsystems/audio/files/common"
+QB_SRC = "${S}/subsystems/audio/files/${SOC_FAMILY}"
+
+# QuickBoot payload library: activation files are staged here and symlinked into
+# /etc at runtime by quickboot-apply on "audio=on".
+QB_PROFILE_DIR = "${datadir}/quickboot/profiles/${SOC_FAMILY}/audio"
+
+QB_INSTALL_COMMON () {
+    install -d ${D}${QB_PROFILE_DIR}
+    install -m 0644 ${QB_COMMON}/pipewire.service             ${D}${QB_PROFILE_DIR}/
+    install -m 0644 ${QB_COMMON}/pipewire.socket.conf         ${D}${QB_PROFILE_DIR}/
+    install -m 0644 ${QB_COMMON}/pipewire-manager.socket.conf ${D}${QB_PROFILE_DIR}/
+    install -m 0644 ${QB_COMMON}/01-pipewire-audio.rules      ${D}${QB_PROFILE_DIR}/
+}
+
+# qcs9100 SoC family (SA8775P / lemans; e.g. iq-9075-evk, qcs9100-ride-sx)
+do_install:qcs9100() {
+    QB_INSTALL_COMMON
+    install -m 0644 ${QB_SRC}/manifest           ${D}${QB_PROFILE_DIR}/
+    install -m 0644 ${QB_SRC}/audio-modules.conf ${D}${QB_PROFILE_DIR}/
+}
+
+# qcm6490 SoC family (sc7280; e.g. rb3gen2-core-kit / Kodiak, qcm6490-idp)
+do_install:qcm6490() {
+    QB_INSTALL_COMMON
+    install -m 0644 ${QB_SRC}/manifest           ${D}${QB_PROFILE_DIR}/
+    install -m 0644 ${QB_SRC}/audio-modules.conf ${D}${QB_PROFILE_DIR}/
+}
+
+FILES:${PN} += "${datadir}/quickboot/profiles"
diff --git a/recipes-quickboot/subsystem/quickboot-camera_1.0.bb b/recipes-quickboot/subsystem/quickboot-camera_1.0.bb
new file mode 100644
index 0000000..4bc3028
--- /dev/null
+++ b/recipes-quickboot/subsystem/quickboot-camera_1.0.bb
@@ -0,0 +1,53 @@
+SUMMARY = "Early Camera Boot Optimizations"
+
+require ../quickboot-git.inc
+
+# Gated on the "quickboot" DISTRO_FEATURE: skipped entirely unless the distro
+# enables it.
+inherit features_check
+REQUIRED_DISTRO_FEATURES = "quickboot"
+
+RDEPENDS:${PN} += "bash quickboot-core"
+
+COMPATIBLE_MACHINE = "(qcm6490|qcs9100)"
+
+# Source slices in the fetched git tree: common (shared) and family payload.
+# examples/camera/ (demo apps) is customer reference only and is NOT installed.
+QB_COMMON = "${S}/subsystems/camera/files/common"
+QB_SRC = "${S}/subsystems/camera/files/${SOC_FAMILY}"
+
+# QuickBoot payload library: activation files (units, udev rules, modules-load.d)
+# are staged here and symlinked into /etc at runtime by quickboot-apply when the
+# user requests "camera=on". They are NOT installed into /etc at build time.
+QB_PROFILE_DIR = "${datadir}/quickboot/profiles/${SOC_FAMILY}/camera"
+
+# qcs9100 SoC family (SA8775P / lemans; e.g. iq-9075-evk, qcs9100-ride-sx)
+QB_INSTALL_COMMON () {
+    install -d ${D}${QB_PROFILE_DIR}
+    install -m 0644 ${QB_COMMON}/cam-server.service  ${D}${QB_PROFILE_DIR}/
+    install -m 0644 ${QB_COMMON}/02-cam-server.rules  ${D}${QB_PROFILE_DIR}/
+}
+
+do_install:qcs9100() {
+    QB_INSTALL_COMMON
+    install -m 0644 ${QB_SRC}/manifest                ${D}${QB_PROFILE_DIR}/
+    install -m 0644 ${QB_SRC}/camera-modules.conf     ${D}${QB_PROFILE_DIR}/
+
+    # First-boot setup script: staged into the payload only (0755 so the
+    # symlink target stays executable); quickboot-apply links it to
+    # /etc/camera/camera-sensor-prune.sh on "camera=on" (see manifest).
+    install -m 0755 ${QB_SRC}/camera-sensor-prune.sh ${D}${QB_PROFILE_DIR}/
+}
+
+# qcm6490 SoC family (sc7280; e.g. rb3gen2-core-kit / Kodiak, qcm6490-idp)
+do_install:qcm6490() {
+    QB_INSTALL_COMMON
+    install -m 0644 ${QB_SRC}/manifest                ${D}${QB_PROFILE_DIR}/
+    install -m 0644 ${QB_SRC}/camera-modules.conf     ${D}${QB_PROFILE_DIR}/
+
+    # CamX override: staged into the payload only; quickboot-apply links it to
+    # /etc/camera/camxoverridesettings.txt on "camera=on" (see manifest).
+    install -m 0644 ${QB_SRC}/camxoverridesettings.txt ${D}${QB_PROFILE_DIR}/
+}
+
+FILES:${PN} += "${datadir}/quickboot/profiles"
