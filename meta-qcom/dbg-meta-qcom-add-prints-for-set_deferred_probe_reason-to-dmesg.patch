diff --git a/recipes-kernel/linux/linux-qcom-6.18/0001-set_defer_probe_reason-for-driver-probe-failures.patch b/recipes-kernel/linux/linux-qcom-6.18/0001-set_defer_probe_reason-for-driver-probe-failures.patch
new file mode 100644
index 00000000..cc8cc44c
--- /dev/null
+++ b/recipes-kernel/linux/linux-qcom-6.18/0001-set_defer_probe_reason-for-driver-probe-failures.patch
@@ -0,0 +1,26 @@
+From d24955447776b773ec2643fd3a065cc4b1f6f2d2 Mon Sep 17 00:00:00 2001
+From: Chitti Babu Theegala <ctheegal@qti.qualcomm.com>
+Date: Tue, 19 May 2026 10:56:09 +0530
+Subject: set_defer_probe_reason for driver probe failures
+
+Upstream-Status: Inappropriate [Yocto specific]
+---
+ drivers/base/core.c | 2 +-
+ 1 file changed, 1 insertion(+), 1 deletion(-)
+
+diff --git a/drivers/base/core.c b/drivers/base/core.c
+index 3099dbca234a..480699360608 100644
+--- a/drivers/base/core.c
++++ b/drivers/base/core.c
+@@ -5010,7 +5010,7 @@ static void __dev_probe_failed(const struct device *dev, int err, bool fatal,
+ 	switch (err) {
+ 	case -EPROBE_DEFER:
+ 		device_set_deferred_probe_reason(dev, &vaf);
+-		dev_dbg(dev, "error %pe: %pV", ERR_PTR(err), &vaf);
++		dev_err(dev, "device_set_deferred_probe_reason: error %pe: %pV", ERR_PTR(err), &vaf);
+ 		break;
+ 
+ 	case -ENOMEM:
